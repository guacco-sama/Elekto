{
  "name": "djcuration",
  "version": "0.1.0",
  "description": "AI-powered DJ music library curation tool",
  "main": "dist-electron/main.js",
  "author": "DJ Curation Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && electron-builder --win",
    "build:linux": "tsc && vite build && electron-builder --linux",
    "lint": "eslint . --ext ts,tsx",
    "worker:build": "cd worker && cargo build --release",
    "worker:dev": "cd worker && cargo run"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0",
    "@tanstack/react-query": "^5.0.0",
    "three": "^0.170.0",
    "@types/three": "^0.170.0",
    "d3": "^7.9.0",
    "@types/d3": "^7.4.0",
    "lucide-react": "^0.460.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "build": {
    "appId": "io.djcuration.app",
    "productName": "DJ Curation",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron",
      "worker/target/release/djcuration-worker"
    ],
    "extraResources": [
      {
        "from": "worker/target/release/djcuration-worker",
        "to": "djcuration-worker"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}